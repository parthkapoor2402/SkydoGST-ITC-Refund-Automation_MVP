{
  "name": "skydo-gst-refund",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "test": "npm run test -w client && npm run test -w server",
    "test:e2e": "playwright test --config playwright.config.mjs --reporter=html",
    "test:ui": "npm run test:ui -w client"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2"
  }
}
